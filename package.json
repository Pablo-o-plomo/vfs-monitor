{
  "name": "adria-travel-monitor",
  "version": "2.0.0",
  "description": "Adria Travel — VFS Global slot monitoring SaaS",
  "scripts": {
    "start": "node src/web/server.js",
    "worker": "node src/worker/index.js",
    "migrate": "node -e \"require('./src/db').migrate().then(() => { console.log('Done'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); })\"",
    "dev": "node -e \"require('./src/db').migrate().then(() => { require('./src/web/server'); require('./src/worker'); })\"",
    "dev:web": "node --watch src/web/server.js",
    "dev:worker": "node --watch src/worker/index.js",
    "postinstall": "npx playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ejs": "^3.1.10",
    "express-session": "^1.18.0",
    "pg": "^8.12.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "playwright": "^1.44.0",
    "express-ejs-layouts": "^2.5.1",
    "node-telegram-bot-api": "^0.66.0",
    "winston": "^3.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}