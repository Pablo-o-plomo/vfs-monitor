<% title = 'Дашборд' %>

<!-- Статус сервисов -->
<div class="svc-row">
  <div class="svc-chip">
    <span class="svc-dot <%= svc.worker === 'ok' ? 'green' : svc.worker === 'warn' ? 'yellow' : svc.worker === 'dead' ? 'red' : '' %>"></span>
    Worker
    <% if (svc.workerAt) { %>
      <span style="color:var(--text2);font-size:11px">• <%= svc.workerAt %></span>
    <% } else { %>
      <span style="color:var(--text2);font-size:11px">• не запускался</span>
    <% } %>
  </div>
  <div class="svc-chip">
    <span class="svc-dot <%= svc.db === 'ok' ? 'green' : 'red' %>"></span>
    PostgreSQL
  </div>
  <div class="svc-chip">
    <span class="svc-dot <%= svc.telegram === 'ok' ? 'green' : 'red' %>"></span>
    Telegram
  </div>
</div>

<!-- Счётчики -->
<div class="stats-grid">
  <div class="stat-card blue">
    <div class="stat-label">Клиентов</div>
    <div class="stat-value"><%= stats.clients %></div>
  </div>
  <div class="stat-card green">
    <div class="stat-label">Активных заявок</div>
    <div class="stat-value"><%= stats.active %></div>
  </div>
  <div class="stat-card yellow">
    <div class="stat-label">На паузе</div>
    <div class="stat-value"><%= stats.paused %></div>
  </div>
  <div class="stat-card" style="<%= stats.error > 0 ? '' : '' %>">
    <div class="stat-label">Ошибок</div>
    <div class="stat-value" style="color:<%= stats.error > 0 ? 'var(--red)' : 'var(--text2)' %>"><%= stats.error %></div>
  </div>
  <div class="stat-card purple">
    <div class="stat-label">Слотов за 24 ч</div>
    <div class="stat-value"><%= stats.slots24h %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Проверок за 24 ч</div>
    <div class="stat-value" style="color:var(--accent)"><%= stats.checks24h %></div>
  </div>
</div>

<!-- Последние слоты -->
<div class="card">
  <div class="card-header">
    🕐 Последние найденные слоты
    <% if (stats.pending > 0) { %>
      <span class="badge badge-idle"><%= stats.pending %> ждут проверки</span>
    <% } %>
  </div>
  <% if (recentSlots.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">🔍</div>
      Слоты ещё не найдены. Worker начнёт проверки когда появятся активные заявки.
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Дата слота</th>
          <th>Время</th>
          <th>Клиент</th>
          <th>Страна / Центр</th>
          <th>Категория</th>
          <th>Найден</th>
        </tr>
      </thead>
      <tbody>
        <% recentSlots.forEach(s => { %>
          <tr>
            <td><b><%= s.slot_date %></b></td>
            <td><%= s.slot_time || '—' %></td>
            <td>
              <a href="/requests/<%= s.request_id %>" class="link"><%= s.client_name %></a>
            </td>
            <td><%= s.country_name %> / <%= s.center %></td>
            <td class="meta"><%= s.category %> / <%= s.subcategory %></td>
            <td class="meta"><%= fmt.dt(s.found_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
