<% title = 'Новая заявка — ' + client.name %>

<div style="max-width:640px">
  <div class="meta" style="margin-bottom:16px">
    <a href="/clients/<%= client.id %>" class="link">← <%= client.name %></a>
  </div>

  <% if (error) { %>
    <div class="alert alert-error">⚠ <%= error %></div>
  <% } %>

  <div class="card">
    <div class="card-header">Параметры мониторинга</div>
    <div style="padding:24px">
      <form action="/clients/<%= client.id %>/requests" method="POST">
        <div class="form-grid">

          <div class="form-group">
            <label>Страна *</label>
            <select name="country_code" id="countryCode">
              <% countries.forEach(c => { %>
                <option value="<%= c.code %>"
                  <%= (values.country_code || 'hun') === c.code ? 'selected' : '' %>>
                  <%= c.name %>
                </option>
              <% }) %>
            </select>
            <input type="hidden" name="country_name" id="countryName" value="">
          </div>

          <div class="form-group">
            <label>Визовый центр *</label>
            <input type="text" name="center"
              value="<%= values.center || '' %>"
              placeholder="Краснодар"
              list="centers-list" required>
            <datalist id="centers-list">
              <option value="Краснодар">
              <option value="Москва">
              <option value="Санкт-Петербург">
              <option value="Екатеринбург">
              <option value="Новосибирск">
              <option value="Казань">
              <option value="Ростов-на-Дону">
              <option value="Уфа">
              <option value="Нижний Новгород">
              <option value="Самара">
              <option value="Красноярск">
              <option value="Воронеж">
              <option value="Волгоград">
            </datalist>
          </div>

          <div class="form-group">
            <label>Категория *</label>
            <select name="category" required>
              <option value="" disabled selected>Выберите...</option>
              <option value="Краткосрочные визы"
                <%= values.category === 'Краткосрочные визы' ? 'selected' : '' %>>Краткосрочные визы</option>
              <option value="Выдача паспортов"
                <%= values.category === 'Выдача паспортов' ? 'selected' : '' %>>Выдача паспортов</option>
              <option value="Премиум-услуги"
                <%= values.category === 'Премиум-услуги' ? 'selected' : '' %>>Премиум-услуги</option>
            </select>
          </div>

          <div class="form-group">
            <label>Подкатегория *</label>
            <input type="text" name="subcategory"
              value="<%= values.subcategory || '' %>"
              placeholder="Туризм"
              list="subcats-list" required>
            <datalist id="subcats-list">
              <option value="Туризм">
              <option value="Деловая поездка">
              <option value="Частная поездка">
              <option value="Транзит">
              <option value="Культурное мероприятие">
              <option value="Спортивное мероприятие">
              <option value="Медицина">
              <option value="Учёба">
            </datalist>
          </div>

          <div class="form-group">
            <label>Дата ОТ *</label>
            <input type="date" name="date_from"
              value="<%= values.date_from || '' %>" required>
          </div>

          <div class="form-group">
            <label>Дата ДО *</label>
            <input type="date" name="date_to"
              value="<%= values.date_to || '' %>" required>
          </div>

          <div class="form-group form-full">
            <label>Примечания</label>
            <textarea name="notes" placeholder="Любые комментарии к заявке..."><%= values.notes || '' %></textarea>
          </div>
        </div>

        <!-- Настройки мониторинга -->
        <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--border)">
          <div style="font-size:12px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:14px">
            ⚙ Настройки мониторинга
          </div>
          <div class="settings-inline">
            <div class="form-group">
              <label>Интервал (мин)</label>
              <input type="number" name="interval_minutes" value="<%= values.interval_minutes || 7 %>" min="3" max="60">
            </div>
            <div class="form-group">
              <label>Разброс (мин)</label>
              <input type="number" name="jitter_minutes" value="<%= values.jitter_minutes || 3 %>" min="0" max="15">
            </div>
            <div class="form-group">
              <label>Лимит уведомлений/день</label>
              <input type="number" name="notify_limit_per_day" value="<%= values.notify_limit_per_day || 5 %>" min="1" max="50">
            </div>
            <div class="form-group">
              <label>Приоритет</label>
              <input type="number" name="priority" value="<%= values.priority || 0 %>" min="0" max="10">
            </div>
            <div class="form-group">
              <label>Telegram клиента (chat_id)</label>
              <input type="text" name="notify_client_telegram" value="<%= values.notify_client_telegram || '' %>" placeholder="-100xxxxxxx">
            </div>
            <div class="form-group" style="justify-content:flex-end">
              <label>&nbsp;</label>
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:var(--text)">
                <input type="checkbox" name="work_night" style="width:auto" <%= values.work_night ? 'checked' : '' %>>
                Проверять ночью (23:00–07:00 МСК)
              </label>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">🚀 Создать и запустить мониторинг</button>
          <a href="/clients/<%= client.id %>" class="btn btn-ghost">Отмена</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Подставляем название страны в hidden поле
const sel = document.getElementById('countryCode');
const nm  = document.getElementById('countryName');
const map = { <%= countries.map(c => `'${c.code}':'${c.name}'`).join(',') %> };
function sync() { nm.value = map[sel.value] || sel.value; }
sel.addEventListener('change', sync);
sync();
</script>
