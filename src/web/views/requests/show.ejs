<% title = vr.country_name + ' / ' + vr.center + ' — ' + vr.client_name %>

<div class="meta" style="margin-bottom:16px">
  <a href="/clients/<%= vr.client_id %>" class="link">← <%= vr.client_name %></a>
  <% if (vr.client_phone) { %>&nbsp;📞 <%= vr.client_phone %><% } %>
</div>

<div class="detail-header">
  <div>
    <h1>🌍 <%= vr.country_name %> — <%= vr.center %></h1>
    <div class="meta" style="margin-top:6px">
      <%= vr.category %> / <%= vr.subcategory %> &nbsp;•&nbsp;
      <%= fmt.date(vr.date_from) %> — <%= fmt.date(vr.date_to) %>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <span class="badge badge-<%= vr.status %>" style="font-size:13px;padding:4px 12px"><%= vr.status %></span>

    <% if (vr.status === 'active') { %>
      <form action="/requests/<%= vr.id %>/pause" method="POST">
        <button class="btn btn-warning btn-sm">⏸ Пауза</button>
      </form>
    <% } else if (vr.status === 'paused' || vr.status === 'error') { %>
      <form action="/requests/<%= vr.id %>/resume" method="POST">
        <button class="btn btn-success btn-sm">▶ Возобновить</button>
      </form>
    <% } %>

    <% if (vr.status !== 'done') { %>
      <form action="/requests/<%= vr.id %>/done" method="POST">
        <button class="btn btn-ghost btn-sm">✓ Завершить</button>
      </form>
    <% } %>

    <form action="/requests/<%= vr.id %>/delete" method="POST"
          onsubmit="return confirm('Удалить заявку и все данные?')">
      <button class="btn btn-danger btn-sm">🗑 Удалить</button>
    </form>
  </div>
</div>

<!-- Worker статус -->
<div class="info-grid" style="margin-bottom:24px">
  <div class="info-item">
    <label>Worker</label>
    <span>
      <% if (vr.job_status) { %>
        <span class="badge badge-<%= vr.job_status %>"><%= vr.job_status %></span>
      <% } else { %>—<% } %>
    </span>
  </div>
  <div class="info-item">
    <label>Последняя проверка</label>
    <span><%= fmt.dt(vr.last_check_at) %></span>
  </div>
  <div class="info-item">
    <label>Следующая проверка</label>
    <span><%= fmt.dt(vr.next_check_at) %></span>
  </div>
  <div class="info-item">
    <label>Всего проверок</label>
    <span><%= vr.total_checks || 0 %></span>
  </div>
  <div class="info-item">
    <label>Ошибок подряд</label>
    <span style="color:<%= (vr.error_count || 0) > 0 ? 'var(--red)' : 'inherit' %>">
      <%= vr.error_count || 0 %>
    </span>
  </div>
  <% if (vr.last_error && vr.job_status !== 'running') { %>
  <div class="info-item" style="grid-column:1/-1">
    <label>Последняя ошибка
      <form action="/requests/<%= vr.id %>/clear-error" method="POST" style="display:inline;margin-left:8px">
        <button type="submit" class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px">✕ Сбросить</button>
      </form>
    </label>
    <div>
      <span style="color:var(--red);font-size:13px">Последняя проверка завершилась ошибкой</span>
      <button type="button" class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px;margin-left:8px"
        onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none';this.textContent=this.textContent==='Подробнее'?'Скрыть':'Подробнее'">Подробнее</button>
      <div style="display:none;margin-top:8px;padding:8px;background:var(--bg2);border-radius:6px;font-size:11px;font-family:monospace;color:var(--red);word-break:break-all"><%= vr.last_error %></div>
    </div>
  </div>
  <% } %>
  <% if (vr.notes) { %>
  <div class="info-item" style="grid-column:1/-1">
    <label>Примечания</label>
    <span><%= vr.notes %></span>
  </div>
  <% } %>
</div>

<!-- Настройки мониторинга -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    ⚙ Настройки мониторинга
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('settings-form').classList.toggle('hidden')" type="button">
      ✏ Изменить
    </button>
  </div>
  <div style="padding:16px 20px">
    <!-- Краткий просмотр -->
    <div id="settings-view" class="settings-inline" style="font-size:13px">
      <div>
        <span class="meta">Интервал</span><br>
        <b><%= vr.interval_minutes || 7 %> мин</b> ± <%= vr.jitter_minutes || 3 %> мин
      </div>
      <div>
        <span class="meta">Лимит уведомлений/день</span><br>
        <b><%= vr.notify_limit_per_day || 5 %></b>
      </div>
      <div>
        <span class="meta">Приоритет</span><br>
        <b><%= vr.priority || 0 %></b>
      </div>
      <div>
        <span class="meta">Ночные проверки</span><br>
        <b><%= vr.work_night ? '✓ Да (24/7)' : '✗ Нет (пауза 23–07 МСК)' %></b>
      </div>
      <% if (vr.notify_client_telegram) { %>
      <div>
        <span class="meta">Telegram клиента</span><br>
        <b><%= vr.notify_client_telegram %></b>
      </div>
      <% } %>
    </div>

    <!-- Форма редактирования (скрыта по умолчанию) -->
    <form id="settings-form" action="/requests/<%= vr.id %>/settings" method="POST"
          class="hidden" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
      <div class="settings-inline">
        <div class="form-group">
          <label>Интервал (мин)</label>
          <input type="number" name="interval_minutes" value="<%= vr.interval_minutes || 7 %>" min="3" max="60">
        </div>
        <div class="form-group">
          <label>Разброс (мин)</label>
          <input type="number" name="jitter_minutes" value="<%= vr.jitter_minutes || 3 %>" min="0" max="15">
        </div>
        <div class="form-group">
          <label>Лимит уведомлений/день</label>
          <input type="number" name="notify_limit_per_day" value="<%= vr.notify_limit_per_day || 5 %>" min="1" max="50">
        </div>
        <div class="form-group">
          <label>Приоритет</label>
          <input type="number" name="priority" value="<%= vr.priority || 0 %>" min="0" max="10">
        </div>
        <div class="form-group">
          <label>Telegram клиента</label>
          <input type="text" name="notify_client_telegram" value="<%= vr.notify_client_telegram || '' %>" placeholder="-100xxxxxxx">
        </div>
        <div class="form-group">
          <label for="work_night_cb">Ночные проверки</label>
          <div>
            <% var workNightChecked = vr.work_night ? 'checked' : ''; %>
            <input type="checkbox" id="work_night_cb" name="work_night" value="on" <%- workNightChecked %>>
            <label for="work_night_cb">Проверять ночью (23–07 МСК)</label>
          </div>
        </div>
      </div>
      <div class="form-actions" style="margin-top:14px">
        <button type="submit" class="btn btn-primary btn-sm">💾 Сохранить</button>
        <button type="button" class="btn btn-ghost btn-sm"
          onclick="document.getElementById('settings-form').classList.add('hidden')">Отмена</button>
      </div>
    </form>
  </div>
</div>

<!-- История проверок -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    🕐 История проверок (<%= history.length %>)
  </div>
  <% if (history.length === 0) { %>
    <div class="empty" style="padding:24px">
      История появится после первой проверки worker'а.
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Время</th><th>Результат</th><th>Слотов</th><th>Уведомление</th></tr>
      </thead>
      <tbody>
        <% history.forEach(h => { %>
          <tr>
            <td class="meta"><%= fmt.dt(h.checked_at) %></td>
            <td>
              <span class="result-<%= h.result %>">
                <%= h.result === 'slot_found' ? '🟢 Найден слот'
                  : h.result === 'no_slots'   ? '○ Нет слотов'
                  : '🔴 Ошибка' %>
              </span>
              <% if (h.error_msg) { %>
                <br><span class="meta" style="font-family:monospace;font-size:11px"><%= h.error_msg.slice(0,80) %></span>
              <% } %>
            </td>
            <td><%= h.slots_count > 0 ? h.slots_count : '—' %></td>
            <td><%= h.notified ? '✓' : '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- Найденные слоты -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    📅 Найденные слоты (<%= slots.length %>)
  </div>
  <% if (slots.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">🔍</div>
      Слоты ещё не найдены. Worker проверяет VFS каждые ~<%= vr.interval_minutes || 7 %> мин.
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Дата</th><th>Время</th><th>Центр</th><th>Найден в</th></tr>
      </thead>
      <tbody>
        <% slots.forEach(s => { %>
          <tr>
            <td><b><%= s.slot_date %></b></td>
            <td><%= s.slot_time || '—' %></td>
            <td><%= s.center || vr.center %></td>
            <td class="meta"><%= fmt.dt(s.found_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- История уведомлений -->
<div class="card">
  <div class="card-header">🔔 