      <thead>
        <tr><th>–Ф–∞—В–∞</th><th>–Т—А–µ–Љ—П</th><th>–¶–µ–љ—В—А</th><th>–Э–∞–є–і–µ–љ –≤</th></tr>
      </thead>
      <tbody>
        <% slots.forEach(s => { %>
          <tr>
            <td><b><%= s.slot_date %></b></td>
