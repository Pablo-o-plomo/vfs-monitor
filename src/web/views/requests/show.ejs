      </tbody>
    </table>
  <% } %>
</div>

<!-- –Ш—Б—В–Њ—А–Є—П —Г–≤–µ–і–Њ–Љ–ї–µ–љ–Є–є -->
<div class="card">
  <div class="card-header">рЯФФ –£–≤–µ–і–Њ–Љ–ї–µ–љ–Є—П (<%= notifications.length %>)</div>
