  <% } else { %>
    <table>
      <thead><tr><th>–Ъ–∞–љ–∞–ї</th><th>–°—В–∞—В—Г—Б</th><th>–Ю—В–њ—А–∞–≤–ї–µ–љ–Њ</th><th>–°–Њ–Њ–±—Й–µ–љ–Є–µ</th></tr></thead>
      <tbody>
        <% notifications.forEach(n => { %>
