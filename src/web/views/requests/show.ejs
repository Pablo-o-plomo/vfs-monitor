  </div>
  <div id="activity-log" style="padding:14px 20px;min-height:48px;max-height:320px;overflow-y:auto">
    <div class="meta" style="font-size:13px">–Ю–ґ–Є–і–∞–µ–Љ –і–∞–љ–љ—Л–µ...</div>
  </div>
</div>

<!-- –Ш—Б—В–Њ—А–Є—П –њ—А–Њ–≤–µ—А–Њ–Ї -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    рЯХР –Ш—Б—В–Њ—А–Є—П –њ—А–Њ–≤–µ—А–Њ–Ї (<%= history.length %>)
  </div>
  <% if (history.length === 0) { %>
    <div class="empty" style="padding:24px">
      –Ш—Б—В–Њ—А–Є—П –њ–Њ—П–≤–Є—В—Б—П –њ–Њ—Б–ї–µ –њ–µ—А–≤–Њ–є –њ—А–Њ–≤–µ—А–Ї–Є worker'–∞.
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr><th>–Т—А–µ–Љ—П</th><th>–†–µ–Ј—Г–ї—М—В–∞—В</th><th>–°–ї–Њ—В–Њ–≤</th><th>–£–≤–µ–і–Њ–Љ–ї–µ–љ–Є–µ</th></tr>
      </thead>
      <tbody>
        <% history.forEach(h => { %>
          <tr>
            <td class="meta"><%= fmt.dt(h.checked_at) %></td>
            <td>
              <span class="result-<%= h.result %>">
                <%= h.result === 'slot_found' ? 'рЯЯҐ –Э–∞–є–і–µ–љ —Б–ї–Њ—В'
                  : h.result === 'no_slots'   ? 'вЧЛ –Э–µ—В —Б–ї–Њ—В–Њ–≤'
                  : 'рЯФі –Ю—И–Є–±–Ї–∞' %>
              </span>
              <% if (h.error_msg) { %>
                <br><span class="meta" style="font-family:monospace;font-size:11px"><%= h.error_msg.slice(0,80) %></span>
              <% } %>
            </td>
            <td><%= h.slots_count > 0 ? h.slots_count : 'вАФ' %></td>
            <td><%= h.notified ? 'вЬУ' : 'вАФ' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- –Э–∞–є–і–µ–љ–љ—Л–µ —Б–ї–Њ—В—Л -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    рЯУЕ –Э–∞–є–і–µ–љ–љ—Л–µ —Б–ї–Њ—В—Л (<%= slots.length %>)
  </div>
  <% if (slots.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">рЯФН</div>
      –°–ї–Њ—В—Л –µ—Й—С –љ–µ –љ–∞–є–і–µ–љ—Л. Worker –њ—А–Њ–≤–µ—А—П–µ—В VFS –Ї–∞–ґ–і—Л–µ ~<%= vr.interval_minutes || 7 %> –Љ–Є–љ.
    </div>
  <% } else { %>
