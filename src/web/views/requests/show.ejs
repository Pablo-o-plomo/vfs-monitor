<% title = vr.country_name + ' / ' + vr.center + ' вАФ ' + vr.client_name %>

<div class="meta" style="margin-bottom:16px">
  <a href="/clients/<%= vr.client_id %>" class="link">вЖР <%= vr.client_name %></a>
  <% if (vr.client_phone) { %>&nbsp;рЯУЮ <%= vr.client_phone %><% } %>
</div>

<div class="detail-header">
  <div>
    <h1>рЯМН <%= vr.country_name %> / <%= vr.center %></h1>
    <div class="meta" style="margin-top:4px;line-height:1.7">
      <span><%= vr.category %> / <%= vr.subcategory %></span><br>
      <span>рЯУЕ <%= fmt.date(vr.date_from) %> вАФ <%= fmt.date(vr.date_to) %></span>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <% if (vr.status === 'done' || vr.status === 'booked') { %>
      <span class="badge" style="background:var(--green);color:#fff;font-size:13px;padding:4px 14px">вЬЕ –Ч–Р–Я–Ш–°–Р–Э</span>
    <% } else { %>
      <span class="badge badge-<%= vr.status %>" style="font-size:13px;padding:4px 12px"><%= vr.status %></span>
    <% } %>

    <% if (vr.status === 'active') { %>
      <form action="/requests/<%= vr.id %>/pause" method="POST">
        <button class="btn btn-warning btn-sm">вПЄ –Я–∞—Г–Ј–∞</button>
      </form>
      <form action="/requests/<%= vr.id %>/check-now" method="POST">
        <button class="btn btn-success btn-sm">рЯФД –Я—А–Њ–≤–µ—А–Є—В—М —Б–µ–є—З–∞—Б</button>
      </form>
      <button type="button" class="btn btn-ghost btn-sm"
        onclick="document.getElementById('params-form-card').classList.toggle('hidden');document.getElementById('params-form-card').scrollIntoView({behavior:'smooth',block:'start'})">
        вЪЩпЄП –Я–∞—А–∞–Љ–µ—В—А—Л –њ–Њ–Є—Б–Ї–∞
      </button>
    <% } else if (vr.status === 'paused' || vr.status === 'error') { %>
      <form action="/requests/<%= vr.id %>/resume" method="POST">
        <button class="btn btn-success btn-sm">вЦґ –Т–Њ–Ј–Њ–±–љ–Њ–≤–Є—В—М</button>
      </form>
    <% } %>

    <% if (vr.status !== 'done') { %>
      <form action="/requests/<%= vr.id %>/done" method="POST">
        <button class="btn btn-ghost btn-sm">вЬУ –Ч–∞–≤–µ—А—И–Є—В—М</button>
      </form>
    <% } %>

    <form action="/requests/<%= vr.id %>/delete" method="POST"
          onsubmit="return confirm('–£–і–∞–ї–Є—В—М –Ј–∞—П–≤–Ї—Г –Є –≤—Б–µ –і–∞–љ–љ—Л–µ?')">
      <button class="btn btn-danger btn-sm">рЯЧС –£–і–∞–ї–Є—В—М</button>
    </form>
  </div>
</div>

<!-- –С–ї–Њ–Ї —Г—Б–њ–µ—И–љ–Њ–≥–Њ –±—А–Њ–љ–Є—А–Њ–≤–∞–љ–Є—П -->
<% if ((vr.status === 'done' || vr.status === 'booked') && vr.booked_at) { %>
<div class="card" style="margin-bottom:20px;border:2px solid var(--green)">
  <div class="card-header" style="color:var(--green)">вЬЕ –Ч–∞–њ–Є—Б—М –Њ—Д–Њ—А–Љ–ї–µ–љ–∞</div>
  <div style="padding:16px 20px">
    <div class="info-grid">
      <div class="info-item">
        <label>–Ф–∞—В–∞ –Ј–∞–њ–Є—Б–Є</label>
        <span style="font-size:18px;font-weight:700"><%= fmt.date(vr.appointment_date) %></span>
      </div>
      <% if (vr.appointment_time) { %>
      <div class="info-item">
        <label>–Т—А–µ–Љ—П</label>
        <span style="font-size:18px;font-weight:700"><%= vr.appointment_time %></span>
      </div>
      <% } %>
      <% if (vr.booking_ref) { %>
      <div class="info-item">
        <label>–Э–Њ–Љ–µ—А –±—А–Њ–љ–Є</label>
        <span style="font-weight:600;font-family:monospace"><%= vr.booking_ref %></span>
      </div>
      <% } %>
      <div class="info-item">
        <label>–Ю—Д–Њ—А–Љ–ї–µ–љ–Њ</label>
        <span class="meta"><%= fmt.dt(vr.booked_at) %> ¬Ј –∞–≤—В–Њ–Љ–∞—В–Є—З–µ—Б–Ї–Є</span>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- –§–Њ—А–Љ–∞ —А–µ–і–∞–Ї—В–Є—А–Њ–≤–∞–љ–Є—П –њ–∞—А–∞–Љ–µ—В—А–Њ–≤ –њ–Њ–Є—Б–Ї–∞ -->
<div id="params-form-card" class="card hidden" style="margin-bottom:20px;border:2px solid var(--accent)">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <span>вЪЩпЄП –Я–∞—А–∞–Љ–µ—В—А—Л –њ–Њ–Є—Б–Ї–∞</span>
    <button type="button" class="btn btn-ghost btn-sm"
      onclick="document.getElementById('params-form-card').classList.add('hidden')">вЬХ –Ч–∞–Ї—А—Л—В—М</button>
  </div>
  <div style="padding:16px 20px">
    <form action="/requests/<%= vr.id %>/params" method="POST">
      <div class="settings-inline">

        <div class="form-group">
          <label>–°—В—А–∞–љ–∞</label>
          <select name="country_code" id="params-country">
            <% countries.forEach(function(c) { %>
              <option value="<%= c.code %>" <%= vr.country_code === c.code ? 'selected' : '' %>><%= c.name %></option>
            <% }); %>
          </select>
        </div>

        <div class="form-group">
          <label>–Т–Є–Ј–Њ–≤—Л–є —Ж–µ–љ—В—А</label>
          <input type="text" id="params-center" name="center" value="<%= vr.center %>"
            placeholder="–Т–Є–Ј–Њ–≤—Л–є —Ж–µ–љ—В—А –Т–µ–љ–≥—А–Є–Є,–Ъ—А–∞—Б–љ–Њ–і–∞—А">
          <div style="display:flex;gap:5px;flex-wrap:wrap;margin-top:6px">
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('–Ъ—А–∞—Б–љ–Њ–і–∞—А')">рЯПЩ –Ъ—А–∞—Б–љ–Њ–і–∞—А</button>
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('–Ь–Њ—Б–Ї–≤–∞')">рЯПЩ –Ь–Њ—Б–Ї–≤–∞</button>
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('–†–Њ—Б—В–Њ–≤-–љ–∞-–Ф–Њ–љ—Г')">рЯПЩ –†–Њ—Б—В–Њ–≤</button>
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('–°–∞–љ–Ї—В-–Я–µ—В–µ—А–±—Г—А–≥')">рЯПЩ –°–Я–±</button>
          </div>
        </div>

        <div class="form-group">
          <label>–Ъ–∞—В–µ–≥–Њ—А–Є—П</label>
          <input type="text" name="category" value="<%= vr.category %>"
            placeholder="–Ъ—А–∞—В–Ї–Њ—Б—А–Њ—З–љ—Л–µ –≤–Є–Ј—Л">
        </div>

        <div class="form-group">
          <label>–Я–Њ–і–Ї–∞—В–µ–≥–Њ—А–Є—П</label>
          <input type="text" name="subcategory" value="<%= vr.subcategory %>"
            placeholder="–Ґ—Г—А–Є–Ј–Љ">
        </div>

        <div class="form-group">
          <label>–Ф–∞—В–∞ –Њ—В</label>
          <input type="date" name="date_from"
            value="<%= vr.date_from ? (vr.date_from.toISOString ? vr.date_from.toISOString().slice(0,10) : String(vr.date_from).slice(0,10)) : '' %>">
        </div>

        <div class="form-group">
          <label>–Ф–∞—В–∞ –і–Њ</label>
          <input type="date" name="date_to"
            value="<%= vr.date_to ? (vr.date_to.toISOString ? vr.date_to.toISOString().slice(0,10) : String(vr.date_to).slice(0,10)) : '' %>">
        </div>

      </div>
      <div class="form-actions" style="margin-top:14px">
        <button type="submit" class="btn btn-primary btn-sm">рЯТЊ –°–Њ—Е—А–∞–љ–Є—В—М –њ–∞—А–∞–Љ–µ—В—А—Л</button>
        <button type="button" class="btn btn-ghost btn-sm"
          onclick="document.getElementById('params-form-card').classList.add('hidden')">–Ю—В–Љ–µ–љ–∞</button>
      </div>
    </form>
    <div class="meta" style="margin-top:10px;font-size:12px">
      вДєпЄП –Я–Њ—Б–ї–µ —Б–Њ—Е—А–∞–љ–µ–љ–Є—П –ї–Њ–≥ —В–µ–Ї—Г—Й–µ–є –њ—А–Њ–≤–µ—А–Ї–Є –±—Г–і–µ—В –Њ—З–Є—Й–µ–љ, —Б–ї–µ–і—Г—О—Й–∞—П –њ—А–Њ–≤–µ—А–Ї–∞ –Ј–∞–њ—Г—Б—В–Є—В—Б—П –љ–µ–Љ–µ–і–ї–µ–љ–љ–Њ.
    </div>
  </div>
</div>

<!-- Live —Б—В–∞—В—Г—Б worker -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <span>вЪ° –°—В–∞—В—Г—Б –Љ–Њ–љ–Є—В–Њ—А–Є–љ–≥–∞</span>
    <span id="live-updated" class="meta" style="font-size:11px"></span>
  </div>
  <div style="padding:14px 20px">
    <!-- –°—В–∞–і–Є—П (–Ї—А—Г–њ–љ–Њ) -->
    <div id="stage-block" style="display:flex;align-items:center;gap:16px;margin-bottom:16px;padding:14px 18px;background:var(--bg2);border-radius:10px;transition:background 0.4s">
      <span id="stage-icon" style="font-size:30px;line-height:1;flex-shrink:0"></span>
      <div>
        <div id="stage-label" style="font-size:17px;font-weight:700;line-height:1.3"></div>
        <div id="stage-time" class="meta" style="font-size:12px;margin-top:3px"></div>
      </div>
    </div>

    <!-- –Ґ–∞–є–Љ–µ—А –Є —Б—В–∞—В–Є—Б—В–Є–Ї–∞ -->
    <div class="info-grid" style="font-size:13px">
      <div class="info-item">
        <label>–°–ї–µ–і—Г—О—Й–∞—П –њ—А–Њ–≤–µ—А–Ї–∞</label>
        <span id="live-timer" style="font-weight:600"></span>
      </div>
      <div class="info-item">
        <label>–Я–Њ—Б–ї–µ–і–љ—П—П –њ—А–Њ–≤–µ—А–Ї–∞</label>
        <span id="live-last-check"></span>
      </div>
      <div class="info-item">
        <label>–Т—Б–µ–≥–Њ –њ—А–Њ–≤–µ—А–Њ–Ї</label>
        <span id="live-total-checks"><%= vr.total_checks || 0 %></span>
      </div>
      <div class="info-item">
        <label>–Ю—И–Є–±–Њ–Ї –њ–Њ–і—А—П–і</label>
        <span id="live-error-count" style="color:<%= (vr.error_count || 0) > 0 ? 'var(--red)' : 'inherit' %>"><%= vr.error_count || 0 %></span>
      </div>
    </div>

    <!-- –С–ї–Њ–Ї –Њ—И–Є–±–Ї–Є -->
    <div id="live-error-block" style="display:none;margin-top:12px;padding:10px 12px;background:var(--bg2);border-radius:6px">
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
        <span style="color:var(--red);font-size:13px">–Я–Њ—Б–ї–µ–і–љ—П—П –њ—А–Њ–≤–µ—А–Ї–∞ –Ј–∞–≤–µ—А—И–Є–ї–∞—Б—М –Њ—И–Є–±–Ї–Њ–є</span>
        <form action="/requests/<%= vr.id %>/clear-error" method="POST" style="display:inline">
          <button type="submit" class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px">вЬХ –°–±—А–Њ—Б–Є—В—М</button>
        </form>
        <button type="button" class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px"
          onclick="var d=document.getElementById('live-error-detail');d.style.display=d.style.display==='none'?'block':'none';this.textContent=this.textContent==='–Я–Њ–і—А–Њ–±–љ–µ–µ'?'–°–Ї—А—Л—В—М':'–Я–Њ–і—А–Њ–±–љ–µ–µ'">–Я–Њ–і—А–Њ–±–љ–µ–µ</button>
        <a href="/requests/<%= vr.id %>/artifacts/last-error.png" target="_blank"
           class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px">рЯУЈ –°–Ї—А–Є–љ—И–Њ—В</a>
        <a href="/requests/<%= vr.id %>/artifacts/last-error.html" target="_blank"
           class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px">рЯМР HTML</a>
      </div>
      <div id="live-error-detail" style="display:none;margin-top:6px;font-size:11px;font-family:monospace;color:var(--red);word-break:break-all"></div>
    </div>

    <% if (vr.notes) { %>
    <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:13px">
      <span class="meta">–Я—А–Є–Љ–µ—З–∞–љ–Є—П: </span><%= vr.notes %>
    </div>
    <% } %>
  </div>
</div>

<!-- –Ф–∞–љ–љ—Л–µ –Ј–∞—П–≤–Є—В–µ–ї—П -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    рЯС§ –Ф–∞–љ–љ—Л–µ –Ј–∞—П–≤–Є—В–µ–ї—П
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('applicant-form').classList.toggle('hidden')" type="button">
      вЬП –Ш–Ј–Љ–µ–љ–Є—В—М
    </button>
  </div>
  <div style="padding:16px 20px">
    <!-- –Я—А–Њ—Б–Љ–Њ—В—А -->
    <div id="applicant-view">
      <% const hasApplicant = vr.first_name || vr.last_name || vr.birth_date || vr.passport_num; %>
      <% if (!hasApplicant) { %>
        <div class="meta" style="font-size:13px">–Ф–∞–љ–љ—Л–µ –љ–µ –Ј–∞–њ–Њ–ї–љ–µ–љ—Л. –Э—Г–ґ–љ—Л –і–ї—П –∞–≤—В–Њ–±—А–Њ–љ–Є—А–Њ–≤–∞–љ–Є—П.</div>
      <% } else { %>
        <div class="info-grid" style="font-size:13px">
          <% if (vr.first_name || vr.last_name) { %>
          <div class="info-item">
            <label>–Ш–Љ—П / –§–∞–Љ–Є–ї–Є—П</label>
            <span><%= [vr.first_name, vr.last_name].filter(Boolean).join(' ') %></span>
          </div>
          <% } %>
          <% if (vr.birth_date) { %>
          <div class="info-item">
            <label>–Ф–∞—В–∞ —А–Њ–ґ–і–µ–љ–Є—П</label>
            <span><%= fmt.date(vr.birth_date) %></span>
          </div>
          <% } %>
          <% if (vr.gender) { %>
          <div class="info-item">
            <label>–Я–Њ–ї</label>
            <span><%= vr.gender === 'M' ? '–Ь—Г–ґ—Б–Ї–Њ–є' : vr.gender === 'F' ? '–Ц–µ–љ—Б–Ї–Є–є' : vr.gender %></span>
          </div>
          <% } %>
          <% if (vr.citizenship) { %>
          <div class="info-item">
            <label>–У—А–∞–ґ–і–∞–љ—Б—В–≤–Њ</label>
            <span><%= vr.citizenship %></span>
          </div>
          <% } %>
          <% if (vr.passport_num) { %>
          <div class="info-item">
            <label>–Э–Њ–Љ–µ—А –њ–∞—Б–њ–Њ—А—В–∞</label>
            <span><%= vr.passport_num %></span>
          </div>
          <% } %>
          <% if (vr.passport_exp) { %>
          <div class="info-item">
            <label>–°—А–Њ–Ї –і–µ–є—Б—В–≤–Є—П –њ–∞—Б–њ–Њ—А—В–∞</label>
            <span><%= fmt.date(vr.passport_exp) %></span>
          </div>
          <% } %>
          <% if (vr.applicant_email) { %>
          <div class="info-item">
            <label>Email –Ј–∞—П–≤–Є—В–µ–ї—П</label>
            <span><%= vr.applicant_email %></span>
          </div>
          <% } %>
          <% if (vr.applicant_phone) { %>
          <div class="info-item">
            <label>–Ґ–µ–ї–µ—Д–Њ–љ –Ј–∞—П–≤–Є—В–µ–ї—П</label>
            <span><%= vr.applicant_phone %></span>
          </div>
          <% } %>
          <% if (vr.auto_book) { %>
          <div class="info-item" style="grid-column:1/-1">
            <span style="color:var(--green);font-weight:600">вЪ° –Р–≤—В–Њ–±—А–Њ–љ–Є—А–Њ–≤–∞–љ–Є–µ –≤–Ї–ї—О—З–µ–љ–Њ</span>
          </div>
          <% } %>
          <% if (vr.comment) { %>
          <div class="info-item" style="grid-column:1/-1">
            <label>–Ъ–Њ–Љ–Љ–µ–љ—В–∞—А–Є–є</label>
            <span><%= vr.comment %></span>
          </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- –§–Њ—А–Љ–∞ —А–µ–і–∞–Ї—В–Є—А–Њ–≤–∞–љ–Є—П -->
    <form id="applicant-form" action="/requests/<%= vr.id %>/applicant" method="POST"
          class="hidden" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
      <div class="settings-inline">
        <div class="form-group">
          <label>–Ш–Љ—П (First Name)</label>
          <input type="text" name="first_name" value="<%= vr.first_name || '' %>" placeholder="IVAN">
        </div>
        <div class="form-group">
          <label>–§–∞–Љ–Є–ї–Є—П (Last Name)</label>
          <input type="text" name="last_name" value="<%= vr.last_name || '' %>" placeholder="IVANOV">
        </div>
        <div class="form-group">
          <label>–Ф–∞—В–∞ —А–Њ–ґ–і–µ–љ–Є—П</label>
          <input type="date" name="birth_date" value="<%= vr.birth_date ? vr.birth_date.toISOString ? vr.birth_date.toISOString().slice(0,10) : String(vr.birth_date).slice(0,10) : '' %>">
        </div>
        <div class="form-group">
          <label>–Я–Њ–ї</label>
          <select name="gender">
            <option value="">вАФ –љ–µ —Г–Ї–∞–Ј–∞–љ вАФ</option>
            <option value="M" <%= vr.gender === 'M' ? 'selected' : '' %>>–Ь—Г–ґ—Б–Ї–Њ–є</option>
            <option value="F" <%= vr.gender === 'F' ? 'selected' : '' %>>–Ц–µ–љ—Б–Ї–Є–є</option>
          </select>
        </div>
        <div class="form-group">
          <label>–У—А–∞–ґ–і–∞–љ—Б—В–≤–Њ</label>
          <input type="text" name="citizenship" value="<%= vr.citizenship || '' %>" placeholder="RUS">
        </div>
        <div class="form-group">
          <label>–Э–Њ–Љ–µ—А –њ–∞—Б–њ–Њ—А—В–∞</label>
          <input type="text" name="passport_num" value="<%= vr.passport_num || '' %>" placeholder="700000000">
        </div>
        <div class="form-group">
          <label>–°—А–Њ–Ї –і–µ–є—Б—В–≤–Є—П –њ–∞—Б–њ–Њ—А—В–∞</label>
          <input type="date" name="passport_exp" value="<%= vr.passport_exp ? String(vr.passport_exp).slice(0,10) : '' %>">
        </div>
        <div class="form-group">
          <label>Email –Ј–∞—П–≤–Є—В–µ–ї—П</label>
          <input type="email" name="applicant_email" value="<%= vr.applicant_email || '' %>">
        </div>
        <div class="form-group">
          <label>–Ґ–µ–ї–µ—Д–Њ–љ –Ј–∞—П–≤–Є—В–µ–ї—П</label>
          <input type="text" name="applicant_phone" value="<%= vr.applicant_phone || '' %>" placeholder="+7...">
        </div>
        <div class="form-group" style="grid-column:1/-1">
          <label>–Ъ–Њ–Љ–Љ–µ–љ—В–∞—А–Є–є</label>
          <input type="text" name="comment" value="<%= vr.comment || '' %>">
        </div>
        <div class="form-group" style="grid-column:1/-1">
          <label for="auto_book_cb">–Р–≤—В–Њ–±—А–Њ–љ–Є—А–Њ–≤–∞–љ–Є–µ</label>
          <div>
            <input type="checkbox" id="auto_book_cb" name="auto_book" value="on" <%= vr.auto_book ? 'checked' : '' %>>
