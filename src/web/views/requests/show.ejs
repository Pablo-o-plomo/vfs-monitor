<% title = vr.country_name + ' / ' + vr.center + ' — ' + vr.client_name %>

<div class="meta" style="margin-bottom:16px">
  <a href="/clients/<%= vr.client_id %>" class="link">← <%= vr.client_name %></a>
  <% if (vr.client_phone) { %>&nbsp;📞 <%= vr.client_phone %><% } %>
</div>

<div class="detail-header">
  <div>
    <h1>🌍 <%= vr.country_name %> / <%= vr.center %></h1>
    <div class="meta" style="margin-top:4px;line-height:1.7">
      <span><%= vr.category %> / <%= vr.subcategory %></span><br>
      <span>📅 <%= fmt.date(vr.date_from) %> — <%= fmt.date(vr.date_to) %></span>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <% if (vr.status === 'done' || vr.status === 'booked') { %>
      <span class="badge" style="background:var(--green);color:#fff;font-size:13px;padding:4px 14px">✅ ЗАПИСАН</span>
    <% } else { %>
      <span class="badge badge-<%= vr.status %>" style="font-size:13px;padding:4px 12px"><%= vr.status %></span>
    <% } %>

    <% if (vr.status === 'active') { %>
      <form action="/requests/<%= vr.id %>/pause" method="POST">
        <button class="btn btn-warning btn-sm">⏸ Пауза</button>
      </form>
      <form action="/requests/<%= vr.id %>/check-now" method="POST">
        <button class="btn btn-success btn-sm">🔄 Проверить сейчас</button>
      </form>
      <button type="button" class="btn btn-ghost btn-sm"
        onclick="document.getElementById('params-form-card').classList.toggle('hidden');document.getElementById('params-form-card').scrollIntoView({behavior:'smooth',block:'start'})">
        ⚙️ Параметры поиска
      </button>
    <% } else if (vr.status === 'paused' || vr.status === 'error') { %>
      <form action="/requests/<%= vr.id %>/resume" method="POST">
        <button class="btn btn-success btn-sm">▶ Возобновить</button>
      </form>
    <% } %>

    <% if (vr.status !== 'done') { %>
      <form action="/requests/<%= vr.id %>/done" method="POST">
        <button class="btn btn-ghost btn-sm">✓ Завершить</button>
      </form>
    <% } %>

    <form action="/requests/<%= vr.id %>/delete" method="POST"
          onsubmit="return confirm('Удалить заявку и все данные?')">
      <button class="btn btn-danger btn-sm">🗑 Удалить</button>
    </form>
  </div>
</div>

<!-- Блок успешного бронирования -->
<% if ((vr.status === 'done' || vr.status === 'booked') && vr.booked_at) { %>
<div class="card" style="margin-bottom:20px;border:2px solid var(--green)">
  <div class="card-header" style="color:var(--green)">✅ Запись оформлена</div>
  <div style="padding:16px 20px">
    <div class="info-grid">
      <div class="info-item">
        <label>Дата записи</label>
        <span style="font-size:18px;font-weight:700"><%= fmt.date(vr.appointment_date) %></span>
      </div>
      <% if (vr.appointment_time) { %>
      <div class="info-item">
        <label>Время</label>
        <span style="font-size:18px;font-weight:700"><%= vr.appointment_time %></span>
      </div>
      <% } %>
      <% if (vr.booking_ref) { %>
      <div class="info-item">
        <label>Номер брони</label>
        <span style="font-weight:600;font-family:monospace"><%= vr.booking_ref %></span>
      </div>
      <% } %>
      <div class="info-item">
        <label>Оформлено</label>
        <span class="meta"><%= fmt.dt(vr.booked_at) %> · автоматически</span>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Форма редактирования параметров поиска -->
<div id="params-form-card" class="card hidden" style="margin-bottom:20px;border:2px solid var(--accent)">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <span>⚙️ Параметры поиска</span>
    <button type="button" class="btn btn-ghost btn-sm"
      onclick="document.getElementById('params-form-card').classList.add('hidden')">✕ Закрыть</button>
  </div>
  <div style="padding:16px 20px">
    <form action="/requests/<%= vr.id %>/params" method="POST">
      <div class="settings-inline">

        <div class="form-group">
          <label>Страна</label>
          <select name="country_code" id="params-country">
            <% countries.forEach(function(c) { %>
              <option value="<%= c.code %>" <%= vr.country_code === c.code ? 'selected' : '' %>><%= c.name %></option>
            <% }); %>
          </select>
        </div>

        <div class="form-group">
          <label>Визовый центр</label>
          <input type="text" id="params-center" name="center" value="<%= vr.center %>"
            placeholder="Визовый центр Венгрии,Краснодар">
          <div style="display:flex;gap:5px;flex-wrap:wrap;margin-top:6px">
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('Краснодар')">🏙 Краснодар</button>
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('Москва')">🏙 Москва</button>
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('Ростов-на-Дону')">🏙 Ростов</button>
            <button type="button" class="btn btn-ghost btn-sm" onclick="setParamsCenter('Санкт-Петербург')">🏙 СПб</button>
          </div>
        </div>

        <div class="form-group">
          <label>Категория</label>
          <input type="text" name="category" value="<%= vr.category %>"
            placeholder="Краткосрочные визы">
        </div>

        <div class="form-group">
          <label>Подкатегория</label>
          <input type="text" name="subcategory" value="<%= vr.subcategory %>"
            placeholder="Туризм">
        </div>

        <div class="form-group">
          <label>Дата от</label>
          <input type="date" name="date_from"
            value="<%= vr.date_from ? (vr.date_from.toISOString ? vr.date_from.toISOString().slice(0,10) : String(vr.date_from).slice(0,10)) : '' %>">
        </div>

        <div class="form-group">
          <label>Дата до</label>
          <input type="date" name="date_to"
            value="<%= vr.date_to ? (vr.date_to.toISOString ? vr.date_to.toISOString().slice(0,10) : String(vr.date_to).slice(0,10)) : '' %>">
        </div>

      </div>
      <div class="form-actions" style="margin-top:14px">
        <button type="submit" class="btn btn-primary btn-sm">💾 Сохранить параметры</button>
        <button type="button" class="btn btn-ghost btn-sm"
          onclick="document.getElementById('params-form-card').classList.add('hidden')">Отмена</button>
      </div>
    </form>
    <div class="meta" style="margin-top:10px;font-size:12px">
      ℹ️ После сохранения лог текущей проверки будет очищен, следующая проверка запустится немедленно.
    </div>
  </div>
</div>

<!-- Live статус worker -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <span>⚡ Статус мониторинга</span>
    <span id="live-updated" class="meta" style="font-size:11px"></span>
  </div>
  <div style="padding:14px 20px">
    <!-- Стадия (крупно) -->
    <div id="stage-block" style="display:flex;align-items:center;gap:16px;margin-bottom:16px;padding:14px 18px;background:var(--bg2);border-radius:10px;transition:background 0.4s">
      <span id="stage-icon" style="font-size:30px;line-height:1;flex-shrink:0"></span>
      <div>
        <div id="stage-label" style="font-size:17px;font-weight:700;line-height:1.3"></div>
        <div id="stage-time" class="meta" style="font-size:12px;margin-top:3px"></div>
      </div>
    </div>

    <!-- Таймер и статистика -->
    <div class="info-grid" style="font-size:13px">
      <div class="info-item">
        <label>Следующая проверка</label>
        <span id="live-timer" style="font-weight:600"></span>
      </div>
      <div class="info-item">
        <label>Последняя проверка</label>
        <span id="live-last-check"></span>
      </div>
      <div class="info-item">
        <label>Всего проверок</label>
        <span id="live-total-checks"><%= vr.total_checks || 0 %></span>
      </div>
      <div class="info-item">
        <label>Ошибок подряд</label>
        <span id="live-error-count" style="color:<%= (vr.error_count || 0) > 0 ? 'var(--red)' : 'inherit' %>"><%= vr.error_count || 0 %></span>
      </div>
    </div>

    <!-- Блок ошибки -->
    <div id="live-error-block" style="display:none;margin-top:12px;padding:10px 12px;background:var(--bg2);border-radius:6px">
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
        <span style="color:var(--red);font-size:13px">Последняя проверка завершилась ошибкой</span>
        <form action="/requests/<%= vr.id %>/clear-error" method="POST" style="display:inline">
          <button type="submit" class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px">✕ Сбросить</button>
        </form>
        <button type="button" class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px"
          onclick="var d=document.getElementById('live-error-detail');d.style.display=d.style.display==='none'?'block':'none';this.textContent=this.textContent==='Подробнее'?'Скрыть':'Подробнее'">Подробнее</button>
        <a href="/requests/<%= vr.id %>/artifacts/last-error.png" target="_blank"
           class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px">📷 Скриншот</a>
        <a href="/requests/<%= vr.id %>/artifacts/last-error.html" target="_blank"
           class="btn btn-ghost btn-sm" style="font-size:11px;padding:2px 8px">🌐 HTML</a>
      </div>
      <div id="live-error-detail" style="display:none;margin-top:6px;font-size:11px;font-family:monospace;color:var(--red);word-break:break-all"></div>
    </div>

    <% if (vr.notes) { %>
    <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:13px">
      <span class="meta">Примечания: </span><%= vr.notes %>
    </div>
    <% } %>
  </div>
</div>


<!-- Сессия VFS истекла: требуется импорт cookies -->
<div id="manual-login-card" style="display:none;margin-bottom:20px;border:2px solid #f90;border-radius:10px;overflow:hidden">
  <div style="background:rgba(255,153,0,0.15);border-bottom:1px solid #f90;padding:12px 18px;display:flex;align-items:center;gap:10px">
    <span style="font-size:24px">⚠️</span>
    <span style="font-size:16px;font-weight:700;color:#f90">Сессия VFS истекла — нужно обновить cookies</span>
  </div>
  <div style="padding:16px 20px">
    <p style="margin:0 0 12px;font-size:14px;line-height:1.6">
      Worker загрузил cookies из базы, но VFS их не принял (сессия истекла или неполна).
      Войдите в VFS вручную в обычном браузере, экспортируйте cookies и загрузите их в систему.
    </p>
    <div style="background:var(--bg2);border-radius:8px;padding:14px 16px;font-size:13px;margin-bottom:14px">
      <b>Инструкция (5 шагов):</b>
      <ol style="margin:10px 0 0;padding-left:18px;line-height:2.4">
        <li>Установите расширение <b>Cookie-Editor</b> в Chrome/Firefox</li>
        <li>Откройте <a href="https://visa.vfsglobal.com/rus/ru/hun/login" target="_blank" style="color:var(--accent)">visa.vfsglobal.com</a> и войдите в аккаунт VFS до страницы <b>/dashboard</b></li>
        <li>Нажмите иконку Cookie-Editor → <b>Export → Export as JSON</b> → сохраните файл как <code>cookies-hun.json</code></li>
        <li>Положите файл в корень папки <code>vfs-monitor</code> и выполните в терминале:<br>
          <code style="display:inline-block;margin-top:6px;background:var(--bg);padding:4px 10px;border-radius:4px;font-size:12px">node tools/import-cookies.js hun cookies-hun.json --verify</code>
        </li>
        <li>Убедитесь что скрипт вывел <b>✅ Верификация УСПЕШНА</b>, затем нажмите кнопку ниже</li>
      </ol>
    </div>
    <form action="/requests/<%= vr.id %>/check-now" method="POST">
      <button type="submit" class="btn btn-primary">
        ✅ Cookies обновлены — Запустить проверку
      </button>
    </form>
  </div>
</div>

<!-- Мини-браузер (live view Playwright) -->
<% if (vr.status === 'active') { %>
<div class="card" id="mini-browser-card" style="margin-bottom:20px">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <span>🖥 Браузер (live)</span>
    <span id="browser-url" class="meta" style="font-size:11px;font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60%"></span>
  </div>
  <div style="padding:0;background:#0a0a0a;border-radius:0 0 10px 10px;overflow:hidden;position:relative;min-height:200px">
    <img id="browser-frame"
      alt="Ожидаем первый кадр..."
      style="width:100%;display:block;image-rendering:auto;transition:opacity 0.1s;opacity:0.2"
      onerror="this.style.opacity='0.2'"
      onload="this.style.opacity='1'"
    >
    <div id="browser-no-data" style="display:none;position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#555;font-size:13px">
      Ожидаем запуск проверки...
    </div>
  </div>
  <div style="padding:6px 14px;font-size:11px;color:var(--muted);display:flex;justify-content:space-between">
    <span id="browser-ts"></span>
    <span>683 × 384 px · ~5 fps</span>
  </div>
</div>

<script>
(function() {
  var rid = '<%= vr.id %>';
  var frameEl  = document.getElementById('browser-frame');
  var urlEl    = document.getElementById('browser-url');
  var tsEl     = document.getElementById('browser-ts');
  var lastTs   = 0;
  var stopped  = false;

  function refreshFrame() {
    if (stopped || document.hidden) return;
    frameEl.src = '/requests/' + rid + '/live-frame.jpg?t=' + Date.now();
  }

  function refreshMeta() {
    if (stopped) return;
    fetch('/requests/' + rid + '/live-frame.json?t=' + Date.now())
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(d) {
        if (!d) return;
        if (d.ts && d.ts !== lastTs) {
          lastTs = d.ts;
          var ago = Math.round((Date.now() - d.ts) / 1000);
          tsEl.textContent = 'Обновлено ' + ago + ' сек. назад';
        }
        if (d.url) {
          var short = d.url.replace(/^https?:\/\/[^\/]+/, '');
          urlEl.textContent = short || d.url;
          urlEl.title = d.url;
        }
      })
      .catch(function() {});
  }

  // Кадры — каждые 500мс, метаданные — каждые 2с
  var frameTimer = setInterval(refreshFrame, 500);
  var metaTimer  = setInterval(refreshMeta,  2000);
  refreshMeta();

  document.addEventListener('visibilitychange', function() {
    if (document.hidden) {
      clearInterval(frameTimer);
      clearInterval(metaTimer);
    } else if (!stopped) {
      frameTimer = setInterval(refreshFrame, 500);
      metaTimer  = setInterval(refreshMeta,  2000);
    }
  });
})();
</script>
<% } %>

<!-- Данные заявителя -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    👤 Данные заявителя
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('applicant-form').classList.toggle('hidden')" type="button">
      ✏ Изменить
    </button>
  </div>
  <div style="padding:16px 20px">
    <!-- Просмотр -->
    <div id="applicant-view">
      <% const hasApplicant = vr.first_name || vr.last_name || vr.birth_date || vr.passport_num; %>
      <% if (!hasApplicant) { %>
        <div class="meta" style="font-size:13px">Данные не заполнены. Нужны для автобронирования.</div>
      <% } else { %>
        <div class="info-grid" style="font-size:13px">
          <% if (vr.first_name || vr.last_name) { %>
          <div class="info-item">
            <label>Имя / Фамилия</label>
            <span><%= [vr.first_name, vr.last_name].filter(Boolean).join(' ') %></span>
          </div>
          <% } %>
          <% if (vr.birth_date) { %>
          <div class="info-item">
            <label>Дата рождения</label>
            <span><%= fmt.date(vr.birth_date) %></span>
          </div>
          <% } %>
          <% if (vr.gender) { %>
          <div class="info-item">
            <label>Пол</label>
            <span><%= vr.gender === 'M' ? 'Мужской' : vr.gender === 'F' ? 'Женский' : vr.gender %></span>
          </div>
          <% } %>
          <% if (vr.citizenship) { %>
          <div class="info-item">
            <label>Гражданство</label>
            <span><%= vr.citizenship %></span>
          </div>
          <% } %>
          <% if (vr.passport_num) { %>
          <div class="info-item">
            <label>Номер паспорта</label>
            <span><%= vr.passport_num %></span>
          </div>
          <% } %>
          <% if (vr.passport_exp) { %>
          <div class="info-item">
            <label>Срок действия паспорта</label>
            <span><%= fmt.date(vr.passport_exp) %></span>
          </div>
          <% } %>
          <% if (vr.applicant_email) { %>
          <div class="info-item">
            <label>Email заявителя</label>
            <span><%= vr.applicant_email %></span>
          </div>
          <% } %>
          <% if (vr.applicant_phone) { %>
          <div class="info-item">
            <label>Телефон заявителя</label>
            <span><%= vr.applicant_phone %></span>
          </div>
          <% } %>
          <% if (vr.auto_book) { %>
          <div class="info-item" style="grid-column:1/-1">
            <span style="color:var(--green);font-weight:600">⚡ Автобронирование включено</span>
          </div>
          <% } %>
          <% if (vr.comment) { %>
          <div class="info-item" style="grid-column:1/-1">
            <label>Комментарий</label>
            <span><%= vr.comment %></span>
          </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Форма редактирования -->
    <form id="applicant-form" action="/requests/<%= vr.id %>/applicant" method="POST"
          class="hidden" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
      <div class="settings-inline">
        <div class="form-group">
          <label>Имя (First Name)</label>
          <input type="text" name="first_name" value="<%= vr.first_name || '' %>" placeholder="IVAN">
        </div>
        <div class="form-group">
          <label>Фамилия (Last Name)</label>
          <input type="text" name="last_name" value="<%= vr.last_name || '' %>" placeholder="IVANOV">
        </div>
        <div class="form-group">
          <label>Дата рождения</label>
          <input type="date" name="birth_date" value="<%= vr.birth_date ? vr.birth_date.toISOString ? vr.birth_date.toISOString().slice(0,10) : String(vr.birth_date).slice(0,10) : '' %>">
        </div>
        <div class="form-group">
          <label>Пол</label>
          <select name="gender">
            <option value="">— не указан —</option>
            <option value="M" <%= vr.gender === 'M' ? 'selected' : '' %>>Мужской</option>
            <option value="F" <%= vr.gender === 'F' ? 'selected' : '' %>>Женский</option>
          </select>
        </div>
        <div class="form-group">
          <label>Гражданство</label>
          <input type="text" name="citizenship" value="<%= vr.citizenship || '' %>" placeholder="RUS">
        </div>
        <div class="form-group">
          <label>Номер паспорта</label>
          <input type="text" name="passport_num" value="<%= vr.passport_num || '' %>" placeholder="700000000">
        </div>
        <div class="form-group">
          <label>Срок действия паспорта</label>
          <input type="date" name="passport_exp" value="<%= vr.passport_exp ? String(vr.passport_exp).slice(0,10) : '' %>">
        </div>
        <div class="form-group">
          <label>Email заявителя</label>
          <input type="email" name="applicant_email" value="<%= vr.applicant_email || '' %>">
        </div>
        <div class="form-group">
          <label>Телефон заявителя</label>
          <input type="text" name="applicant_phone" value="<%= vr.applicant_phone || '' %>" placeholder="+7...">
        </div>
        <div class="form-group" style="grid-column:1/-1">
          <label>Комментарий</label>
          <input type="text" name="comment" value="<%= vr.comment || '' %>">
        </div>
        <div class="form-group" style="grid-column:1/-1">
          <label for="auto_book_cb">Автобронирование</label>
          <div>
            <input type="checkbox" id="auto_book_cb" name="auto_book" value="on" <%= vr.auto_book ? 'checked' : '' %>>
            <label for="auto_book_cb">⚡ Автоматически бронировать найденный слот</label>
          </div>
        </div>
      </div>
      <div class="form-actions" style="margin-top:14px">
        <button type="submit" class="btn btn-primary">💾 Сохранить данные заявителя</button>
        <button type="button" class="btn btn-ghost btn-sm"
          onclick="document.getElementById('applicant-form').classList.add('hidden')">Отмена</button>
      </div>
    </form>
  </div>
</div>

<!-- Настройки мониторинга -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    ⚙ Настройки мониторинга
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('settings-form').classList.toggle('hidden')" type="button">
      ✏ Изменить
    </button>
  </div>
  <div style="padding:16px 20px">
    <div id="settings-view" class="settings-inline" style="font-size:13px">
      <div>
        <span class="meta">Интервал</span><br>
        <b><%= vr.interval_minutes || 7 %> мин</b> ± <%= vr.jitter_minutes || 3 %> мин
      </div>
      <div>
        <span class="meta">Лимит уведомлений/день</span><br>
        <b><%= vr.notify_limit_per_day || 5 %></b>
      </div>
      <div>
        <span class="meta">Приоритет</span><br>
        <b><%= vr.priority || 0 %></b>
      </div>
      <div>
        <span class="meta">Ночные проверки</span><br>
        <b><%= vr.work_night ? '✓ Да (24/7)' : '✗ Нет (пауза 23–07 МСК)' %></b>
      </div>
      <% if (vr.notify_client_telegram) { %>
      <div>
        <span class="meta">Telegram клиента</span><br>
        <b><%= vr.notify_client_telegram %></b>
      </div>
      <% } %>
    </div>

    <form id="settings-form" action="/requests/<%= vr.id %>/settings" method="POST"
          class="hidden" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
      <div class="settings-inline">
        <div class="form-group">
          <label>Интервал (мин)</label>
          <input type="number" name="interval_minutes" value="<%= vr.interval_minutes || 7 %>" min="3" max="60">
        </div>
        <div class="form-group">
          <label>Разброс (мин)</label>
          <input type="number" name="jitter_minutes" value="<%= vr.jitter_minutes || 3 %>" min="0" max="15">
        </div>
        <div class="form-group">
          <label>Лимит уведомлений/день</label>
          <input type="number" name="notify_limit_per_day" value="<%= vr.notify_limit_per_day || 5 %>" min="1" max="50">
        </div>
        <div class="form-group">
          <label>Приоритет</label>
          <input type="number" name="priority" value="<%= vr.priority || 0 %>" min="0" max="10">
        </div>
        <div class="form-group">
          <label>Telegram клиента</label>
          <input type="text" name="notify_client_telegram" value="<%= vr.notify_client_telegram || '' %>" placeholder="-100xxxxxxx">
        </div>
        <div class="form-group">
          <label for="work_night_cb">Ночные проверки</label>
          <div>
            <% var workNightChecked = vr.work_night ? 'checked' : ''; %>
            <input type="checkbox" id="work_night_cb" name="work_night" value="on" <%- workNightChecked %>>
            <label for="work_night_cb">Проверять ночью (23–07 МСК)</label>
          </div>
        </div>
      </div>
      <div class="form-actions" style="margin-top:14px">
        <button type="submit" class="btn btn-primary btn-sm">💾 Сохранить</button>
        <button type="button" class="btn btn-ghost btn-sm"
          onclick="document.getElementById('settings-form').classList.add('hidden')">Отмена</button>
      </div>
    </form>
  </div>
</div>

<!-- Лог активности (live) -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <span>📋 Лог текущей проверки</span>
    <span id="log-updated" class="meta" style="font-size:11px"></span>
  </div>
  <div id="activity-log" style="padding:14px 20px;min-height:48px;max-height:320px;overflow-y:auto">
    <div class="meta" style="font-size:13px">Ожидаем данные...</div>
  </div>
</div>

<!-- История проверок -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    🕐 История проверок (<%= history.length %>)
  </div>
  <% if (history.length === 0) { %>
    <div class="empty" style="padding:24px">
      История появится после первой проверки worker'а.
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Время</th><th>Результат</th><th>Слотов</th><th>Уведомление</th></tr>
      </thead>
      <tbody>
        <% history.forEach(h => { %>
          <tr>
            <td class="meta"><%= fmt.dt(h.checked_at) %></td>
            <td>
              <span class="result-<%= h.result %>">
                <%= h.result === 'slot_found' ? '🟢 Найден слот'
                  : h.result === 'no_slots'   ? '○ Нет слотов'
                  : '🔴 Ошибка' %>
              </span>
              <% if (h.error_msg) { %>
                <br><span class="meta" style="font-family:monospace;font-size:11px"><%= h.error_msg.slice(0,80) %></span>
              <% } %>
            </td>
            <td><%= h.slots_count > 0 ? h.slots_count : '—' %></td>
            <td><%= h.notified ? '✓' : '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- Найденные слоты -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    📅 Найденные слоты (<%= slots.length %>)
  </div>
  <% if (slots.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">🔍</div>
      Слоты ещё не найдены. Worker проверяет VFS каждые ~<%= vr.interval_minutes || 7 %> мин.
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Дата</th><th>Время</th><th>Центр</th><th>Найден в</th></tr>
      </thead>
      <tbody>
        <% slots.forEach(s => { %>
          <tr>
            <td><b><%= s.slot_date %></b></td>
            <td><%= s.slot_time || '—' %></td>
            <td><%= s.center || vr.center %></td>
            <td class="meta"><%= fmt.dt(s.found_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- История уведомлений -->
<div class="card">
  <div class="card-header">🔔 Уведомления (<%= notifications.length %>)</div>
  <% if (notifications.length === 0) { %>
    <div class="empty" style="padding:24px">Уведомлений не было</div>
  <% } else { %>
    <table>
      <thead><tr><th>Канал</th><th>Статус</th><th>Отправлено</th><th>Сообщение</th></tr></thead>
      <tbody>
        <% notifications.forEach(n => { %>
          <tr>
            <td><%= n.channel %></td>
            <td><span class="badge badge-<%= n.status %>"><%= n.status %></span></td>
            <td class="meta"><%= fmt.dt(n.sent_at) %></td>
            <td class="meta" style="max-width:300px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
              <%= n.message ? n.message.slice(0,80) : '—' %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<style>
.hidden { display: none !important; }
</style>

<script>
// Быстрая смена города центра
function setParamsCenter(city) {
  var inp = document.getElementById('params-center');
  if (inp) inp.value = city;
}

// ── Live-поллинг заявки ─────────────────────────────────────────────────────
(function() {
  var rid = '<%= vr.id %>';

  var ICONS = {
    waiting: '⏳', opening_vfs: '🌐', login: '🔐',
    login_manual_required: '⚠️',
    selecting_country: '🌍', selecting_center: '📍', selecting_category: '📋',
    checking_slots: '🔍', calendar_waiting: '📅', calendar_open: '📅',
    searching_dates: '🔍', slot_found: '🎉', no_slots: '😔',
    banner_out_of_range: '📅', slot_in_range: '🎉', banner_error: '⚠️',
    filling_applicant: '📝', selecting_time: '⏰', confirming: '✅',
    booked: '🎉', booking_failed: '❌', done: '✓',
    error: '❌', retry: '🔄', running: '⚙️', start: '▶',
    screenshot: '📷', url_info: '🔗', page_info: '📄',
  };

  var stageBlock      = document.getElementById('stage-block');
  var stageIcon       = document.getElementById('stage-icon');
  var stageLabel      = document.getElementById('stage-label');
  var stageTime       = document.getElementById('stage-time');
  var liveTimer       = document.getElementById('live-timer');
  var liveLastCheck   = document.getElementById('live-last-check');
  var liveTotalChecks = document.getElementById('live-total-checks');
  var liveErrorCount  = document.getElementById('live-error-count');
  var liveUpdated     = document.getElementById('live-updated');
  var liveErrBlock    = document.getElementById('live-error-block');
  var liveErrDetail   = document.getElementById('live-error-detail');
  var activityLog     = document.getElementById('activity-log');
  var logUpdated      = document.getElementById('log-updated');
  var manualCard      = document.getElementById('manual-login-card');

  var nextCheckMs = 0;
  var lastLogLen  = 0;
  var timerInt    = null;

  function fmtAgo(ts) {
    if (!ts) return '—';
    var s = Math.round((Date.now() - new Date(ts).getTime()) / 1000);
    if (s < 0)   return 'сейчас';
    if (s < 60)  return s + ' сек назад';
    return Math.floor(s / 60) + ' мин назад';
  }

  function updateTimer() {
    if (!liveTimer || !nextCheckMs) return;
    var s = Math.round((nextCheckMs - Date.now()) / 1000);
    if (s <= 0) { liveTimer.textContent = 'Сейчас'; return; }
    if (s < 60) { liveTimer.textContent = 'через ' + s + ' сек'; return; }
    var m = Math.floor(s / 60), r = s % 60;
    liveTimer.textContent = 'через ' + m + ' мин' + (r > 0 ? ' ' + r + ' с' : '');
  }

  function pollLive() {
    fetch('/api/requests/' + rid + '/live?_=' + Date.now())
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(d) {
        if (!d) return;

        var stage = d.stage || 'waiting';

        // Иконка и подпись стадии
        if (stageIcon)  stageIcon.textContent  = ICONS[stage] || '⚙️';
        if (stageLabel) stageLabel.textContent  = d.stage_label || stage;
        if (stageTime)  stageTime.textContent   = d.stage_updated_at ? fmtAgo(d.stage_updated_at) : '';

        // Фон блока
        if (stageBlock) {
          stageBlock.style.background =
            stage === 'login_manual_required' ? 'rgba(255,153,0,0.12)' :
            (stage === 'slot_found' || stage === 'booked') ? 'rgba(0,200,100,0.10)' :
            stage === 'error' ? 'rgba(255,80,80,0.10)' : 'var(--bg2)';
        }

        // Карточка ручного входа
        if (manualCard) {
          manualCard.style.display = stage === 'login_manual_required' ? 'block' : 'none';
        }

        // Таймер следующей проверки
        if (d.next_check_at) {
          nextCheckMs = new Date(d.next_check_at).getTime();
          if (!timerInt) timerInt = setInterval(updateTimer, 1000);
          updateTimer();
        }

        // Последняя проверка
        if (liveLastCheck) liveLastCheck.textContent = fmtAgo(d.last_check_at);

        // Статистика
        if (liveTotalChecks) liveTotalChecks.textContent = d.total_checks || 0;
        if (liveErrorCount) {
          liveErrorCount.textContent  = d.error_count || 0;
          liveErrorCount.style.color  = (d.error_count || 0) > 0 ? 'var(--red)' : 'inherit';
        }

        // Блок ошибки (скрыть при manual_required — там есть карточка)
        if (liveErrBlock) {
          if (d.last_error && (d.error_count || 0) > 0 && stage !== 'login_manual_required') {
            liveErrBlock.style.display = 'block';
            if (liveErrDetail) liveErrDetail.textContent = d.last_error || '';
          } else {
            liveErrBlock.style.display = 'none';
          }
        }

        // Лог стадий
        if (activityLog && d.stage_log) {
          if (d.stage_log.length !== lastLogLen) {
            lastLogLen = d.stage_log.length;
            var html = '';
            var entries = d.stage_log.slice().reverse();
            entries.forEach(function(entry) {
              var t   = new Date(entry.logged_at);
              var ts  = t.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
              html += '<div style="padding:3px 0;font-size:12px;display:flex;gap:8px;border-bottom:1px solid var(--border)">'
                + '<span class="meta" style="white-space:nowrap;min-width:60px">' + ts + '</span>'
                + '<span>' + (entry.message || entry.stage) + '</span>'
                + '</div>';
            });
            activityLog.innerHTML = html || '<div clas