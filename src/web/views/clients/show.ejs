<% title = client.name %>
<% topbarActions = `<a href="/clients/${client.id}/requests/new" class="btn btn-primary">+ Новая заявка</a>` %>

<div class="detail-header">
  <div>
    <h1>👤 <%= client.name %></h1>
    <div class="meta" style="margin-top:6px">
      <% if (client.phone) { %><span>📞 <%= client.phone %></span>&nbsp; <% } %>
      <% if (client.email) { %><span>✉ <%= client.email %></span>&nbsp; <% } %>
      <span>Клиент с <%= fmt.date(client.created_at) %></span>
    </div>
    <% if (client.notes) { %>
      <p class="meta" style="margin-top:8px"><%= client.notes %></p>
    <% } %>
  </div>
  <form action="/clients/<%= client.id %>/delete" method="POST"
        onsubmit="return confirm('Удалить клиента и все его заявки?')">
    <button class="btn btn-danger btn-sm">🗑 Удалить</button>
  </form>
</div>

<div class="card">
  <div class="card-header">
    Заявки на мониторинг (<%= requests.length %>)
    <a href="/clients/<%= client.id %>/requests/new" class="btn btn-primary btn-sm">+ Добавить</a>
  </div>

  <% if (requests.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">📋</div>
      Нет заявок. <a href="/clients/<%= client.id %>/requests/new" class="link">Создать первую →</a>
    </div>
  <% } else { %>
    <div class="req-cards">
      <% requests.forEach(r => { %>
        <div class="req-card">
          <!-- Заголовок -->
          <div class="req-card-title">
            🌍 <%= r.country_name %> — <%= r.center %>
          </div>

          <!-- Детали -->
          <div class="req-card-meta">
            <%= r.category %> / <%= r.subcategory %><br>
            📅 <%= fmt.date(r.date_from) %> — <%= fmt.date(r.date_to) %>
          </div>

          <!-- Слоты -->
          <% if (parseInt(r.slots_found) > 0) { %>
            <div style="color:var(--green);font-size:12px;font-weight:600">
              ✓ Найдено слотов: <%= r.slots_found %>
            </div>
          <% } %>

          <!-- Нижняя часть -->
          <div class="req-card-footer">
            <div class="req-card-badges">
              <span class="badge badge-<%= r.status %>"><%= r.status %></span>
              <% if (r.job_status) { %>
                <span class="badge badge-<%= r.job_status %>"><%= r.job_status %></span>
              <% } %>
              <% if (r.error_count > 0) { %>
                <span class="badge badge-error"><%= r.error_count %> err</span>
              <% } %>
              <% if (r.priority > 0) { %>
                <span class="badge" style="background:rgba(124,58,237,.15);color:#a78bfa">⬆ p<%= r.priority %></span>
              <% } %>
            </div>
            <a href="/requests/<%= r.id %>" class="btn btn-ghost btn-sm">Открыть →</a>
          </div>

          <!-- Время последней проверки -->
          <% if (r.last_check_at) { %>
            <div class="meta" style="font-size:11px">
              Проверка: <%= fmt.dt(r.last_check_at) %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
