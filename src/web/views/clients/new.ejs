<% title = 'Новый клиент' %>

<div style="max-width:560px">
  <% if (error) { %>
    <div class="alert alert-error">⚠ <%= error %></div>
  <% } %>

  <div class="card">
    <div class="card-header">Данные клиента</div>
    <div style="padding:24px">
      <form action="/clients" method="POST">
        <div class="form-grid">
          <div class="form-group form-full">
            <label>Имя / Название *</label>
            <input type="text" name="name" value="<%= values.name || '' %>" autofocus required placeholder="Иван Иванов">
          </div>
          <div class="form-group">
            <label>Телефон</label>
            <input type="text" name="phone" value="<%= values.phone || '' %>" placeholder="+7 900 000-00-00">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="<%= values.email || '' %>" placeholder="client@mail.ru">
          </div>
          <div class="form-group form-full">
            <label>Примечания</label>
            <textarea name="notes" placeholder="Любые заметки о клиенте..."><%= values.notes || '' %></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Создать клиента</button>
          <a href="/clients" class="btn btn-ghost">Отмена</a>
        </div>
      </form>
    </div>
  </div>
</div>
