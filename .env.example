# ── Обязательные переменные окружения ──────────────────────────────────

# PostgreSQL (Railway выдаёт автоматически при добавлении Postgres плагина)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram бот для уведомлений менеджеру
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Пароль для входа в веб-панель
ADMIN_PASSWORD=your_strong_password_here

# Учётная запись VFS Global (тестовый аккаунт агентства)
VFS_EMAIL=vfs_test@youragency.com
VFS_PASSWORD=vfs_password_here

# ── Необязательные настройки ────────────────────────────────────────────

# Порт веб-сервера (Railway устанавливает автоматически)
# PORT=3000

# Как часто worker опрашивает БД на наличие заданий (мс, default: 60000)
# WORKER_POLL_MS=60000

# Интервал проверки VFS по умолчанию (мин, default: 7)
# DEFAULT_CHECK_MIN=7

# Разброс интервала ±N мин (default: 3)
# CHECK_JITTER_MIN=3

# TTL дедупликации уведомлений (мс, default: 3600000 = 1 час)
# DEDUP_TTL_MS=3600000

# Файл сессии браузера (по умолчанию ./session.json)
# SESSION_FILE=./session.json
