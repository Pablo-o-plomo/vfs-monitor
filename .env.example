# VFS Global credentials (тестовый аккаунт)
VFS_EMAIL=your_test_email@example.com
VFS_PASSWORD=your_password

# Параметры записи
VFS_COUNTRY=hun                  # hun = Венгрия
VFS_CENTER=Краснодар             # Часть названия визового центра (для матчинга)
VFS_CATEGORY=Краткосрочные       # Часть названия категории
VFS_SUBCATEGORY=Туризм

# Диапазон дат для поиска (YYYY-MM-DD)
DATE_FROM=2026-07-01
DATE_TO=2026-08-31

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx   # ID канала или чата (с минусом для каналов)

# Интервал проверки (минуты). Рекомендуется 5-15
CHECK_INTERVAL_MIN=7
CHECK_INTERVAL_JITTER=3          # ±рандом к интервалу (минуты)

# Файл для хранения сессии
SESSION_FILE=./session.json
